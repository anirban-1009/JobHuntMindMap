<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background: #2c3e50; color: #fff; padding: 10px; text-align: center; border-radius: 5px 5px 0 0; }
        .job-card { border: 1px solid #ddd; margin-bottom: 20px; border-radius: 5px; overflow: hidden; }
        .job-header { background: #f9f9f9; padding: 10px; border-bottom: 1px solid #ddd; }
        .job-title { margin: 0; color: #2980b9; font-size: 1.2em; }
        .company { font-weight: bold; color: #555; }
        .score { display: inline-block; padding: 3px 8px; border-radius: 3px; font-weight: bold; font-size: 0.9em; }
        .score-high { background-color: #27ae60; color: white; }
        .score-mid { background-color: #f39c12; color: white; }
        .job-body { padding: 10px; }
        .reasoning { font-style: italic; color: #666; font-size: 0.9em; margin-top: 10px; }
        .footer { text-align: center; font-size: 0.8em; color: #888; margin-top: 20px; }
        .button { display: inline-block; background-color: #2980b9; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; margin-top: 15px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Daily Job Digest</h1>
        </div>
        <p>Hi {{ user_name }},</p>
        <p>Here are the latest high-matching job opportunities found for you today:</p>
        
        {% for item in jobs %}
        <div class="job-card">
            <div class="job-header">
                <h2 class="job-title">{{ item.job.title }}</h2>
                <div class="company">{{ item.job.company }} | {{ item.job.location }}</div>
                <div class="score {% if item.score.score >= 80 %}score-high{% else %}score-mid{% endif %}">
                    Match Score: {{ item.score.score }}%
                </div>
            </div>
            <div class="job-body">
                <div><strong>Match Highlights:</strong></div>
                <ul>
                    {% for skill in item.score.key_matches %}
                    <li>{{ skill }}</li>
                    {% endfor %}
                </ul>
                <div class="reasoning">
                    "{{ item.score.reasoning }}"
                </div>
                <a href="{{ item.job.link }}" class="button">View Job</a>
            </div>
        </div>
        {% endfor %}

        <div class="footer">
            <p>Generated by Job Hunt Mind Mapper</p>
            <p>Change your preferences in <code>config.yaml</code></p>
        </div>
    </div>
</body>
</html>
